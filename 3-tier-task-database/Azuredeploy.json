{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "adminUsername": {
      "type": "string",
      "minLength": 3,
      "maxLength": 20,
      "metadata": {
        "description": "Administrator username for all VMs."
      }
    },
    "adminPassword": {
      "type": "securestring",
      "minLength": 12,
      "metadata": {
        "description": "VM admin password (uppercase+lowercase+number+special, min 12 chars)."
      }
    },
    "sqlServerName": {
      "type": "string",
      "metadata": {
        "description": "Globally unique Azure SQL logical server name (lowercase, no spaces)."
      }
    },
    "sqlAdminLogin": {
      "type": "string",
      "defaultValue": "sqladmin",
      "metadata": {
        "description": "Azure SQL administrator login."
      }
    },
    "sqlAdminPassword": {
      "type": "securestring",
      "minLength": 12,
      "metadata": {
        "description": "Azure SQL administrator password."
      }
    },
    "location": {
      "type": "string",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Storage account hosting the scripts blob container (anonymous read enabled)."
      }
    },
    "scriptsContainerName": {
      "type": "string",
      "defaultValue": "vm-scripts",
      "metadata": {
        "description": "Blob container name where PS1 scripts are uploaded."
      }
    },
    "webVmSize": {
      "type": "string"
    },
    "appVmSize": {
      "type": "string"
    }
  },
  "variables": {
    "vnetName": "three-tier-vnet",
    "vnetPrefix": "10.0.0.0/16",
    "webSubnetName": "web-subnet",
    "webSubnetPrefix": "10.0.1.0/24",
    "appSubnetName": "app-subnet",
    "appSubnetPrefix": "10.0.2.0/24",
    "dataSubnetName": "data-subnet",
    "dataSubnetPrefix": "10.0.3.0/24",
    "webNsgName": "web-nsg",
    "appNsgName": "app-nsg",
    "dataNsgName": "data-nsg",
    "natGwName": "app-data-natgw",
    "natGwPipName": "natgw-public-ip",
    "publicLbName": "web-public-lb",
    "publicLbPipName": "web-lb-public-ip",
    "publicLbFEName": "web-lb-frontend",
    "publicLbBEName": "web-backend-pool",
    "publicLbProbeName": "web-http-probe",
    "publicLbRuleName": "web-http-rule",
    "privateLbName": "app-private-lb",
    "privateLbFEName": "app-lb-frontend",
    "privateLbFEIp": "10.0.2.100",
    "privateLbBEName": "app-backend-pool",
    "privateLbProbeName": "app-http-probe",
    "privateLbRuleName": "app-http-rule",
    "webVm1Name": "web-vm-1",
    "webVm2Name": "web-vm-2",
    "appVm1Name": "app-vm-1",
    "appVm2Name": "app-vm-2",
    "windowsPublisher": "MicrosoftWindowsServer",
    "windowsOffer": "WindowsServer",
    "windowsSku": "2022-datacenter-azure-edition",
    "sqlDatabaseName": "SampleDB",
    "sqlFwRuleName": "AllowAzureServices",
    "sqlPrivateEndpointName": "sql-private-endpoint",
    "sqlPrivateDnsZoneName": "privatelink.database.windows.net",
    "sqlFqdn": "[concat(parameters('sqlServerName'), '.database.windows.net')]",
    "deployScriptIdName": "deploy-script-identity",
    "scriptBaseUrl": "[concat('https://', parameters('storageAccountName'), '.blob.core.windows.net/', parameters('scriptsContainerName'), '/')]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-04-01",
      "name": "[variables('webNsgName')]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "Allow-HTTP-Inbound",
            "properties": {
              "description": "HTTP through public LB",
              "priority": 100,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "Internet",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "80"
            }
          },
          {
            "name": "Allow-HTTPS-Inbound",
            "properties": {
              "description": "HTTPS through public LB",
              "priority": 110,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "Internet",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "443"
            }
          },
          {
            "name": "Allow-AzureLB-Probe",
            "properties": {
              "description": "Standard LB health probes",
              "priority": 120,
              "protocol": "*",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "AzureLoadBalancer",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "*"
            }
          },
          {
            "name": "Deny-All-Other-Inbound",
            "properties": {
              "description": "",
              "priority": 4000,
              "protocol": "*",
              "access": "Deny",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "*"
            }
          },
          {
            "name": "Allow-VNet-Outbound",
            "properties": {
              "description": "Outbound to app tier",
              "priority": 100,
              "protocol": "*",
              "access": "Allow",
              "direction": "Outbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "VirtualNetwork",
              "destinationPortRange": "*"
            }
          },
          {
            "name": "Allow-Internet-Outbound",
            "properties": {
              "description": "LB SNAT for updates + script download",
              "priority": 110,
              "protocol": "*",
              "access": "Allow",
              "direction": "Outbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "Internet",
              "destinationPortRange": "*"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-04-01",
      "name": "[variables('appNsgName')]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "Allow-HTTP-From-WebSubnet",
            "properties": {
              "description": "HTTP from web subnet only",
              "priority": 100,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "[variables('webSubnetPrefix')]",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "80"
            }
          },
          {
            "name": "Allow-AzureLB-Probe",
            "properties": {
              "description": "Internal LB health probes",
              "priority": 110,
              "protocol": "*",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "AzureLoadBalancer",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "*"
            }
          },
          {
            "name": "Deny-Internet-Inbound",
            "properties": {
              "description": "App tier must NOT be publicly accessible",
              "priority": 200,
              "protocol": "*",
              "access": "Deny",
              "direction": "Inbound",
              "sourceAddressPrefix": "Internet",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "*"
            }
          },
          {
            "name": "Deny-All-Other-Inbound",
            "properties": {
              "description": "",
              "priority": 4000,
              "protocol": "*",
              "access": "Deny",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "*"
            }
          },
          {
            "name": "Allow-SQL-Outbound",
            "properties": {
              "description": "SQL to private endpoint",
              "priority": 100,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Outbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "[variables('dataSubnetPrefix')]",
              "destinationPortRange": "1433"
            }
          },
          {
            "name": "Allow-Internet-Outbound",
            "properties": {
              "description": "NAT GW for updates + script download",
              "priority": 110,
              "protocol": "*",
              "access": "Allow",
              "direction": "Outbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "Internet",
              "destinationPortRange": "*"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-04-01",
      "name": "[variables('dataNsgName')]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "Allow-SQL-From-VNet",
            "properties": {
              "description": "SQL from any VNet subnet (app VMs + private tools)",
              "priority": 100,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "VirtualNetwork",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "1433"
            }
          },
          {
            "name": "Deny-All-Inbound",
            "properties": {
              "description": "Data subnet fully isolated from internet",
              "priority": 4000,
              "protocol": "*",
              "access": "Deny",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "*"
            }
          },
          {
            "name": "Deny-Internet-Outbound",
            "properties": {
              "description": "Private endpoint needs no outbound internet",
              "priority": 100,
              "protocol": "*",
              "access": "Deny",
              "direction": "Outbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "Internet",
              "destinationPortRange": "*"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-04-01",
      "name": "[variables('natGwPipName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static"
      }
    },
    {
      "type": "Microsoft.Network/natGateways",
      "apiVersion": "2023-04-01",
      "name": "[variables('natGwName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', variables('natGwPipName'))]"
      ],
      "properties": {
        "publicIpAddresses": [
          {
            "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('natGwPipName'))]"
          }
        ],
        "idleTimeoutInMinutes": 4
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-04-01",
      "name": "[variables('publicLbPipName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static",
        "dnsSettings": {
          "domainNameLabel": "[concat('weblb-', uniqueString(resourceGroup().id))]"
        }
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-04-01",
      "name": "[variables('vnetName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('webNsgName'))]",
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('appNsgName'))]",
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('dataNsgName'))]",
        "[resourceId('Microsoft.Network/natGateways', variables('natGwName'))]"
      ],
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[variables('vnetPrefix')]"
          ]
        },
        "subnets": [
          {
            "name": "[variables('webSubnetName')]",
            "properties": {
              "addressPrefix": "[variables('webSubnetPrefix')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('webNsgName'))]"
              }
            }
          },
          {
            "name": "[variables('appSubnetName')]",
            "properties": {
              "addressPrefix": "[variables('appSubnetPrefix')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('appNsgName'))]"
              },
              "natGateway": {
                "id": "[resourceId('Microsoft.Network/natGateways', variables('natGwName'))]"
              }
            }
          },
          {
            "name": "[variables('dataSubnetName')]",
            "properties": {
              "addressPrefix": "[variables('dataSubnetPrefix')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('dataNsgName'))]"
              },
              "privateEndpointNetworkPolicies": "Disabled"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[variables('deployScriptIdName')]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceGroup().id, variables('deployScriptIdName'), 'contributor')]",
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('deployScriptIdName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'b24988ac-6180-42a0-ab88-20f7382dd24c')]",
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('deployScriptIdName'))).principalId]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Sql/servers",
      "apiVersion": "2022-05-01-preview",
      "name": "[parameters('sqlServerName')]",
      "location": "[parameters('location')]",
      "properties": {
        "administratorLogin": "[parameters('sqlAdminLogin')]",
        "administratorLoginPassword": "[parameters('sqlAdminPassword')]",
        "publicNetworkAccess": "Enabled",
        "minimalTlsVersion": "1.2"
      }
    },
    {
      "type": "Microsoft.Sql/servers/firewallRules",
      "apiVersion": "2022-05-01-preview",
      "name": "[concat(parameters('sqlServerName'), '/', variables('sqlFwRuleName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', parameters('sqlServerName'))]"
      ],
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      }
    },
    {
      "type": "Microsoft.Sql/servers/databases",
      "apiVersion": "2022-05-01-preview",
      "name": "[concat(parameters('sqlServerName'), '/', variables('sqlDatabaseName'))]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', parameters('sqlServerName'))]"
      ],
      "sku": {
        "name": "GP_S_Gen5",
        "tier": "GeneralPurpose",
        "family": "Gen5",
        "capacity": 1
      },
      "properties": {
        "collation": "SQL_Latin1_General_CP1_CI_AS",
        "maxSizeBytes": 5368709120,
        "autoPauseDelay": 60,
        "minCapacity": 0.5,
        "zoneRedundant": false,
        "requestedBackupStorageRedundancy": "Local"
      }
    },
    {
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2020-06-01",
      "name": "[variables('sqlPrivateDnsZoneName')]",
      "location": "global",
      "properties": {}
    },
    {
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2020-06-01",
      "name": "[concat(variables('sqlPrivateDnsZoneName'), '/vnet-link')]",
      "location": "global",
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', variables('sqlPrivateDnsZoneName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ],
      "properties": {
        "virtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
        },
        "registrationEnabled": false
      }
    },
    {
      "type": "Microsoft.Network/privateEndpoints",
      "apiVersion": "2023-04-01",
      "name": "[variables('sqlPrivateEndpointName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', parameters('sqlServerName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ],
      "properties": {
        "subnet": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), variables('dataSubnetName'))]"
        },
        "privateLinkServiceConnections": [
          {
            "name": "sql-pe-connection",
            "properties": {
              "privateLinkServiceId": "[resourceId('Microsoft.Sql/servers', parameters('sqlServerName'))]",
              "groupIds": [
                "sqlServer"
              ]
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
      "apiVersion": "2023-04-01",
      "name": "[concat(variables('sqlPrivateEndpointName'), '/sql-dns-zone-group')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateEndpoints', variables('sqlPrivateEndpointName'))]",
        "[resourceId('Microsoft.Network/privateDnsZones', variables('sqlPrivateDnsZoneName'))]",
        "[resourceId('Microsoft.Network/privateDnsZones/virtualNetworkLinks', variables('sqlPrivateDnsZoneName'), 'vnet-link')]"
      ],
      "properties": {
        "privateDnsZoneConfigs": [
          {
            "name": "sql-dns-config",
            "properties": {
              "privateDnsZoneId": "[resourceId('Microsoft.Network/privateDnsZones', variables('sqlPrivateDnsZoneName'))]"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Resources/deploymentScripts",
      "apiVersion": "2023-08-01",
      "name": "create-products-table",
      "location": "[parameters('location')]",
      "kind": "AzurePowerShell",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('deployScriptIdName'))]": {}
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('deployScriptIdName'))]",
        "[guid(resourceGroup().id, variables('deployScriptIdName'), 'contributor')]",
        "[resourceId('Microsoft.Sql/servers/databases', parameters('sqlServerName'), variables('sqlDatabaseName'))]",
        "[resourceId('Microsoft.Sql/servers/firewallRules', parameters('sqlServerName'), variables('sqlFwRuleName'))]"
      ],
      "properties": {
        "azPowerShellVersion": "9.0",
        "retentionInterval": "PT1H",
        "timeout": "PT30M",
        "cleanupPreference": "OnSuccess",
        "environmentVariables": [
          {
            "name": "SQL_FQDN",
            "value": "[variables('sqlFqdn')]"
          },
          {
            "name": "SQL_USER",
            "value": "[parameters('sqlAdminLogin')]"
          },
          {
            "name": "SQL_PASS",
            "secureValue": "[parameters('sqlAdminPassword')]"
          }
        ],
        "scriptContent": "\n$fqdn    = $env:SQL_FQDN\n$user    = $env:SQL_USER\n$pass    = $env:SQL_PASS\n$connStr = \"Server=$fqdn,1433;Database=SampleDB;User Id=$user;Password=$pass;Encrypt=True;TrustServerCertificate=True;Connection Timeout=30;\"\n\n$sql = @\"\nIF NOT EXISTS (SELECT * FROM sys.tables WHERE name='Products' AND schema_id=SCHEMA_ID('dbo'))\nBEGIN\n    CREATE TABLE dbo.Products (\n        ID       INT           NOT NULL PRIMARY KEY,\n        Name     NVARCHAR(100) NOT NULL,\n        Price    DECIMAL(10,2) NOT NULL,\n        Category NVARCHAR(50)  NOT NULL,\n        Stock    INT           NOT NULL DEFAULT 0\n    );\n    INSERT INTO dbo.Products (ID,Name,Price,Category,Stock) VALUES\n    (1,'Laptop Pro 15',1299.99,'Electronics',45),\n    (2,'Wireless Mouse',29.99,'Accessories',200),\n    (3,'USB-C Hub 7-Port',49.99,'Accessories',150),\n    (4,'Monitor 27 inch 4K',399.99,'Electronics',30),\n    (5,'Mechanical Keyboard',89.99,'Accessories',75),\n    (6,'Webcam HD 1080p',59.99,'Electronics',90),\n    (7,'SSD 1TB NVMe',109.99,'Electronics',120),\n    (8,'Laptop Stand',34.99,'Accessories',180),\n    (9,'Noise Cancelling Headphones',199.99,'Electronics',55),\n    (10,'Ethernet Cable 10ft',8.99,'Accessories',300);\n    SELECT 'CREATED' AS Status;\nEND\nELSE\n    SELECT 'EXISTS' AS Status;\n\"@\n\n$DeploymentScriptOutputs = @{}\n$maxAttempts = 20\nfor ($i = 1; $i -le $maxAttempts; $i++) {\n    try {\n        Write-Output \"[$i/$maxAttempts] Connecting to $fqdn ...\"\n        $conn = New-Object System.Data.SqlClient.SqlConnection($connStr)\n        $conn.Open()\n        $cmd = $conn.CreateCommand()\n        $cmd.CommandText = $sql\n        $cmd.CommandTimeout = 60\n        $reader = $cmd.ExecuteReader()\n        $status = \"\"\n        while ($reader.Read()) { $status = $reader[\"Status\"] }\n        $reader.Close()\n        $conn.Close()\n        Write-Output \"SUCCESS \u2014 Products table status: $status\"\n        $DeploymentScriptOutputs[\"result\"] = \"Products table $status\"\n        break\n    } catch {\n        Write-Output \"Attempt $i failed: $($_.Exception.Message)\"\n        if ($i -eq $maxAttempts) { throw \"All $maxAttempts attempts failed. Last error: $($_.Exception.Message)\" }\n        Write-Output \"Retrying in 30 seconds...\"\n        Start-Sleep 30\n    }\n}\n"
      }
    },
    {
      "type": "Microsoft.Network/loadBalancers",
      "apiVersion": "2023-04-01",
      "name": "[variables('publicLbName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', variables('publicLbPipName'))]"
      ],
      "properties": {
        "frontendIPConfigurations": [
          {
            "name": "[variables('publicLbFEName')]",
            "properties": {
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('publicLbPipName'))]"
              }
            }
          }
        ],
        "backendAddressPools": [
          {
            "name": "[variables('publicLbBEName')]"
          }
        ],
        "probes": [
          {
            "name": "[variables('publicLbProbeName')]",
            "properties": {
              "protocol": "Http",
              "port": 80,
              "requestPath": "/health.html",
              "intervalInSeconds": 15,
              "numberOfProbes": 2
            }
          }
        ],
        "loadBalancingRules": [
          {
            "name": "[variables('publicLbRuleName')]",
            "properties": {
              "frontendIPConfiguration": {
                "id": "[resourceId('Microsoft.Network/loadBalancers/frontendIPConfigurations', variables('publicLbName'), variables('publicLbFEName'))]"
              },
              "backendAddressPool": {
                "id": "[resourceId('Microsoft.Network/loadBalancers/backendAddressPools',        variables('publicLbName'), variables('publicLbBEName'))]"
              },
              "probe": {
                "id": "[resourceId('Microsoft.Network/loadBalancers/probes',                     variables('publicLbName'), variables('publicLbProbeName'))]"
              },
              "protocol": "Tcp",
              "frontendPort": 80,
              "backendPort": 80,
              "enableFloatingIP": false,
              "idleTimeoutInMinutes": 15,
              "loadDistribution": "SourceIPProtocol",
              "disableOutboundSnat": true
            }
          }
        ],
        "outboundRules": [
          {
            "name": "web-snat-outbound",
            "properties": {
              "frontendIPConfigurations": [
                {
                  "id": "[resourceId('Microsoft.Network/loadBalancers/frontendIPConfigurations', variables('publicLbName'), variables('publicLbFEName'))]"
                }
              ],
              "backendAddressPool": {
                "id": "[resourceId('Microsoft.Network/loadBalancers/backendAddressPools', variables('publicLbName'), variables('publicLbBEName'))]"
              },
              "protocol": "All",
              "idleTimeoutInMinutes": 15,
              "allocatedOutboundPorts": 10000
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/loadBalancers",
